generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model projects {
  id          String   @id
  name        String
  client      String
  location    String
  region      String?  @default("South")
  manager     String
  start_date  DateTime @db.Date
  end_date    DateTime @db.Date
  progress    Int?     @default(0)
  status      String?  @default("Planned")
  budget      Decimal? @default(0) @db.Decimal(12, 2)
  budget_used Decimal? @default(0) @db.Decimal(12, 2)
  description String?
  team        String[] @default([])
  created_at  DateTime? @default(now()) @db.Timestamptz()
  updated_at  DateTime? @default(now()) @db.Timestamptz()

  milestones  milestones[]
  tasks       tasks[]
}

model milestones {
  id         Int      @id @default(autoincrement())
  project_id String
  name       String
  date       DateTime @db.Date
  status     String?  @default("pending")
  sort_order Int?     @default(0)

  project    projects @relation(fields: [project_id], references: [id], onDelete: Cascade)
}

model tasks {
  id          String   @id
  project_id  String?
  parent_id   String?
  name        String
  assigned_to String?
  start_date  DateTime? @db.Date
  end_date    DateTime? @db.Date
  duration    String?
  dependency  String?
  progress    Int?     @default(0)
  status      String?  @default("Planned")
  priority    String?  @default("Medium")
  sort_order  Int?     @default(0)

  project     projects? @relation(fields: [project_id], references: [id], onDelete: Cascade)
  parent      tasks?    @relation("TaskHierarchy", fields: [parent_id], references: [id], onDelete: Cascade)
  children    tasks[]   @relation("TaskHierarchy")
}

model kanban_tasks {
  id            String   @id
  title         String
  project       String?
  priority      String?  @default("Medium")
  assignee      String?
  due_date      DateTime? @db.Date
  comments      Int?     @default(0)
  attachments   Int?     @default(0)
  tags          String[] @default([])
  column_status String?  @default("backlog")
}

model team_members {
  id              Int      @id @default(autoincrement())
  name            String
  role            String?
  avatar          String?
  initials        String?
  tasks_count     Int?     @default(0)
  completed_count Int?     @default(0)
  load            String?  @default("Low")
  projects        String[] @default([])
  skills          String[] @default([])
}

model assets {
  id            String   @id
  name          String
  category      String?
  location      String?
  status        String?  @default("In Warehouse")
  project       String?
  serial_number String?
  purchase_date DateTime? @db.Date
}

model activities {
  id         Int      @id @default(autoincrement())
  type       String?  @default("blue")
  text       String
  time       String?
  created_at DateTime? @default(now()) @db.Timestamptz()
}

model roles {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  color       String?  @default("#2563EB")
  is_system   Boolean? @default(false)
  created_at  DateTime? @default(now()) @db.Timestamptz()

  role_permissions role_permissions[]
  users            users[]
}

model permissions {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  name        String
  description String?
  module      String

  role_permissions role_permissions[]
}

model role_permissions {
  role_id       Int
  permission_id Int

  role       roles       @relation(fields: [role_id], references: [id], onDelete: Cascade)
  permission permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade)

  @@id([role_id, permission_id])
}

model users {
  id          Int      @id @default(autoincrement())
  name        String
  email       String   @unique
  initials    String?
  avatar      String?  @default("bg-1")
  role_id     Int?
  status      String?  @default("Active")
  department  String?
  phone       String?
  last_active DateTime? @default(now()) @db.Timestamptz()
  created_at  DateTime? @default(now()) @db.Timestamptz()

  role        roles?   @relation(fields: [role_id], references: [id], onDelete: SetNull)
}

// ===== Finance Module =====

model billing_ledger {
  id                 Int      @id @default(autoincrement())
  project_id         String?
  vendor_name        String?
  invoice_number     String?
  invoice_date       DateTime? @db.Date
  description        String?
  invoice_amount     Decimal? @db.Decimal(12, 2)
  gst_amount         Decimal? @db.Decimal(12, 2)
  total_amount       Decimal? @db.Decimal(12, 2)
  bill_received_date DateTime? @db.Date
  payment_due_date   DateTime? @db.Date
  payment_status     String?  @default("Pending")
  payment_date       DateTime? @db.Date
  payment_mode       String?
  attachment_url     String?
  created_at         DateTime? @default(now()) @db.Timestamptz()
}

model accrual_budget {
  id              Int      @id @default(autoincrement())
  project_id      String?
  month           String?
  department      String?
  cost_category   String?
  budget_amount   Decimal? @db.Decimal(12, 2)
  actual_accrual  Decimal? @db.Decimal(12, 2)
  variance        Decimal? @db.Decimal(12, 2)
  notes           String?
  created_at      DateTime? @default(now()) @db.Timestamptz()
}

model bills_received {
  id              Int      @id @default(autoincrement())
  vendor_name     String?
  project_id      String?
  invoice_number  String?
  invoice_date    DateTime? @db.Date
  amount          Decimal? @db.Decimal(12, 2)
  department      String?
  approval_status String?  @default("Pending")
  approved_by     String?
  payment_status  String?  @default("Unpaid")
  due_date        DateTime? @db.Date
  created_at      DateTime? @default(now()) @db.Timestamptz()
}

model payments {
  id               Int      @id @default(autoincrement())
  vendor_name      String?
  invoice_number   String?
  payment_amount   Decimal? @db.Decimal(12, 2)
  payment_date     DateTime? @db.Date
  payment_mode     String?
  reference_number String?
  project_id       String?
  remarks          String?
  status           String?  @default("Pending")
  created_at       DateTime? @default(now()) @db.Timestamptz()
}

model vendors {
  id         Int      @id @default(autoincrement())
  name       String
  contact    String?
  email      String?
  gst_number String?
  created_at DateTime? @default(now()) @db.Timestamptz()
}

model departments {
  id         Int      @id @default(autoincrement())
  name       String
  created_at DateTime? @default(now()) @db.Timestamptz()
}
